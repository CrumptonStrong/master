                        <div>
                            <h4 class="text-sm font-black text-amber-500 uppercase">The Penthouse</h4>
                            <p class="text-[10px] text-slate-400">Winner Takes: <span class="text-green-400 font-bold">$500.00</span></p>
                        </div>
                        <div class="flex gap-2 items-center">
                            <div class="bg-slate-950 border border-slate-800 px-3 py-1 rounded text-center">
                                <span class="text-[9px] text-slate-500 block leading-none">FEE</span>
                                <span class="text-xs text-green-400 font-mono font-bold">$300.00</span>
                            </div>
                            <button onclick="playTournamentRun('penthouse_h2h', 'cash')" class="bg-amber-600 hover:bg-amber-500 text-slate-950 font-black px-4 py-2 rounded text-[10px] uppercase tracking-wider">Play</button>
                        </div>
                    </div>

                    <h2 class="branding-font text-sm font-black text-blue-400 uppercase tracking-wider sticky top-0 bg-slate-950/90 py-2 z-10 border-b border-slate-800 mt-6">Practice Rounds</h2>

                    <div class="bg-slate-900 border border-slate-800 rounded-xl p-3 flex items-center justify-between shadow-md">
                        <div>
                            <h4 class="text-sm font-black text-white uppercase">Food Stamp Shootout</h4>
                            <p class="text-[10px] text-slate-400">Warm up the skills.</p>
                        </div>
                        <div class="flex gap-2 items-center">
                            <div class="bg-slate-950 border border-slate-800 px-3 py-1 rounded text-center">
                                <span class="text-[9px] text-slate-500 block leading-none">FEE</span>
                                <span class="text-xs text-blue-400 font-mono font-bold">🎫 3</span>
                            </div>
                            <button onclick="playTournamentRun('practice', 'stamps')" class="bg-blue-600 hover:bg-blue-500 text-white font-black px-4 py-2 rounded text-[10px] uppercase tracking-wider">Play</button>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-2xl flex flex-col h-full max-h-[500px]">
                    <div class="bg-slate-950 border-b border-slate-800 p-3 flex justify-between items-center">
                        <div class="flex items-center gap-2">
                            <span class="text-xl">🍸</span>
                            <h3 class="branding-font text-sm font-black text-white uppercase tracking-wider">The Lounge</h3>
                        </div>
                        <span class="text-[10px] text-green-400 font-mono animate-pulse bg-green-950/30 px-2 py-1 rounded border border-green-900">142 Online</span>
                    </div>

                    <div id="chat-feed" class="flex-grow p-4 overflow-y-auto space-y-4 text-sm scroll-smooth match-scroll bg-slate-900/50">
                        <div class="text-center text-[10px] text-slate-500 font-mono my-2 border-b border-slate-800/50 pb-2">
                            Welcome to the Brickyard. Keep it clean.
                        </div>
                        <div class="flex flex-col gap-1">
                            <div class="flex items-baseline gap-2">
                                <span class="text-amber-500 font-bold text-xs uppercase tracking-wider">TulsaHustle918</span>
                                <span class="text-slate-300 text-xs">Anyone running the Penthouse tonight?</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-slate-950 border-t border-slate-800 p-2 flex gap-2">
                        <input type="text" id="chat-input" placeholder="Talk your talk..." class="flex-grow bg-slate-900 text-white text-xs px-3 py-2 rounded border border-slate-700 outline-none focus:border-amber-500 transition-colors">
                        <button onclick="sendChatMessage()" class="bg-amber-600 hover:bg-amber-500 text-slate-950 font-black px-4 py-2 rounded text-xs uppercase tracking-wider transition-colors shadow-sm">Send</button>
                    </div>
                </div>

            </div>
        </section>

        <section id="screen-game" class="screen w-full max-w-6xl mx-auto my-auto aspect-video relative flex-col items-center justify-center border-[12px] border-slate-900/50 rounded-[3rem] shadow-2xl overflow-hidden backdrop-blur-sm table-shadow mt-4">
            
            <div class="table-logo-badge" aria-hidden="true">
                <img src="logo.avif" alt="Brickyard Dominoes" class="w-32 drop-shadow-xl">
            </div>

            <div id="city-watermark" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center pointer-events-none z-0 opacity-[0.07] flex flex-col items-center">
                <h2 id="city-watermark-title" class="branding-font text-5xl md:text-7xl font-black text-white whitespace-nowrap">WELCOME TO THE BRICKYARD</h2>
                <p id="city-watermark-sub" class="font-mono text-2xl text-amber-500 font-bold tracking-widest mt-2">INDOOR HIGH STAKES</p>
            </div>

            <div class="absolute top-4 right-4 z-20">
                <button onclick="navigate('screen-lobby')" class="bg-slate-900 border border-slate-700 text-slate-300 hover:text-white px-4 py-2 rounded-lg text-xs font-bold tracking-wider uppercase shadow-lg transition-colors">Leave Table</button>
            </div>

            <div id="score-hud" class="absolute top-6 left-0 right-0 px-20 flex justify-between uppercase text-xs font-bold tracking-widest z-20 pointer-events-none">
                <div class="bg-slate-900/90 p-4 rounded-xl border-l-4 border-amber-500 shadow-xl backdrop-blur">You: <span id="my-score-display" class="text-3xl block text-white mt-1">0</span></div>
                <div class="bg-slate-900/90 p-4 rounded-xl border-r-4 border-red-500 text-right shadow-xl backdrop-blur">Opponent: <span class="text-3xl block text-white mt-1">0</span></div>
            </div>

            <div id="active-domino-train" class="absolute inset-x-4 top-1/2 -translate-y-1/2 flex items-center justify-center gap-2 overflow-x-auto p-4 z-10" aria-live="polite">
                </div>

            <div id="player-hand" class="absolute bottom-6 flex gap-4 h-28 z-20 bg-slate-900/60 p-4 rounded-2xl backdrop-blur-md border border-slate-800 shadow-2xl">
                <div class="domino-tile skin-ivory w-12 h-20 flex-col shadow-lg hover:-translate-y-2 transition-transform" role="img" aria-label="Domino 6 and 6" tabindex="0">
                    <div class="h-1/2 flex items-center justify-center" aria-hidden="true"><span class="text-2xl font-black">⚅</span></div>
                    <div class="w-4/5 h-[2px] opacity-40 bg-slate-900" aria-hidden="true"></div>
                    <div class="h-1/2 flex items-center justify-center" aria-hidden="true"><span class="text-2xl font-black">⚅</span></div>
                </div>
            </div>
        </section>

    </main>

    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-functions-compat.js"></script>
    <script src="firebase-config.js"></script>

    <script>
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();
        const auth = firebase.auth();
        const functions = firebase.functions();

        let currentUser = null;
        let confirmationResult = null;

        // ==========================================
        // SPA NAVIGATION SYSTEM
        // ==========================================
        function navigate(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
            
            if(screenId === 'screen-landing') {
                document.getElementById('global-header').classList.add('hidden');
            } else {
                document.getElementById('global-header').classList.remove('hidden');
            }
        }

        // ==========================================
        // UX POLISH: TOAST & LOADER ENGINE
        // ==========================================
        function showLoader(message = "PROCESSING...") {
            const overlay = document.getElementById('loading-overlay');
            overlay.querySelector('h2').innerText = message;
            overlay.classList.remove('hidden');
        }

        function hideLoader() {
            document.getElementById('loading-overlay').classList.add('hidden');
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            const bgClass = type === 'success' ? 'bg-slate-900 border-amber-500' : 'bg-red-950 border-red-500';
            const icon = type === 'success' ? '🏆' : '⚠️';

            toast.className = `${bgClass} border shadow-2xl p-4 rounded-xl flex items-center gap-3 transform translate-x-full transition-transform duration-300 pointer-events-auto`;
            toast.innerHTML = `<span class="text-xl">${icon}</span><span class="text-white text-xs font-bold uppercase tracking-wider">${message}</span>`;

            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.remove('translate-x-full'));
            setTimeout(() => {
                toast.classList.add('translate-x-full');
                setTimeout(() => toast.remove(), 300);
            }, 3500);
        }

        // ==========================================
        // ACTION BUTTON LOGIC
        // ==========================================
        function handlePlayClick() {
            if (!currentUser) {
                document.getElementById('auth-modal').classList.remove('hidden');
            } else {
                navigate('screen-lobby');
            }
        }

        function handleLocationClick() {
            if (!currentUser) {
                document.getElementById('auth-modal').classList.remove('hidden');
            } else {
                document.getElementById('location-modal').classList.remove('hidden');
            }
        }

        function handleLoginToggle() {
            if (currentUser) {
                auth.signOut().then(() => showToast("Logged Out Successfully", "success"));
            } else {
                document.getElementById('auth-modal').classList.remove('hidden');
            }
        }

        // ==========================================
        // AUTHENTICATION LOGIC
        // ==========================================
        window.onload = () => {
            window.recaptchaVerifier = new firebase.auth.RecaptchaVerifier('recaptcha-container', {
                'size': 'normal',
                'callback': (response) => {}
            });
        };

        auth.onAuthStateChanged(async (user) => {
            const loginBtn = document.getElementById('btn-login-top');
            
            if (!user) {
                currentUser = null;
                loginBtn.innerText = "LOG IN";
            } else {
                currentUser = user;
                loginBtn.innerText = "LOG OUT";
                
                const playerRef = db.collection('player_stats').doc(user.uid);
                try {
                    const docSnap = await playerRef.get();
                    if (!docSnap.exists) {
                        const defaultProfile = {
                            uid: user.uid,
                            phoneNumber: user.phoneNumber, 
                            displayName: "Hustler_" + user.uid.substring(0, 5),
                            avatar: "🧢", 
                            balance: 20.00,
                            foodStamps: 100,
                            createdAt: firebase.firestore.FieldValue.serverTimestamp()
                        };
                        await playerRef.set(defaultProfile);
                        updatePlayerHUD(defaultProfile);
                    } else {
                        updatePlayerHUD(docSnap.data());
                    }
                } catch (error) {
                    console.error("Profile sync error:", error);
                }
            }
        });

        function closeAuthModal() {
            document.getElementById('auth-modal').classList.add('hidden');
            resetAuthUI();
        }

        function sendOTP() {
            const tosAccepted = document.getElementById('tos-checkbox').checked;
            if (!tosAccepted) return showToast("You must accept the Terms of Service.", "error");

            const phoneNumber = document.getElementById('phone-number').value.trim();
            if(!phoneNumber.startsWith('+')) return showToast("Use international format (+1)", "error");
            
            showLoader("SENDING CODE...");
            auth.signInWithPhoneNumber(phoneNumber, window.recaptchaVerifier)
                .then((result) => {
                    hideLoader();
                    confirmationResult = result;
                    document.getElementById('phone-input-section').classList.add('hidden');
                    document.getElementById('otp-input-section').classList.remove('hidden');
                    showToast("SMS Sent!", "success");
                }).catch((error) => {
                    hideLoader();
                    showToast("Failed to send code.", "error");
                });
        }

        function verifyOTP() {
            const code = document.getElementById('otp-code').value.trim();
            showLoader("VERIFYING...");
            confirmationResult.confirm(code).then((result) => {
                hideLoader();
                closeAuthModal();
                showToast("Identity Secured.", "success");
                
                // Immediately drop them into the lobby upon successful login
                navigate('screen-lobby');
            }).catch((error) => {
                hideLoader();
                showToast("Invalid Code.", "error");
            });
        }

        function resetAuthUI() {
            document.getElementById('otp-input-section').classList.add('hidden');
            document.getElementById('phone-input-section').classList.remove('hidden');
        }

        function updatePlayerHUD(profileData) {
            if (profileData.displayName) document.getElementById('player-name-display').innerText = profileData.displayName;
            if (profileData.avatar) document.getElementById('player-avatar-display').innerText = profileData.avatar;
            if (profileData.balance !== undefined) document.getElementById('player-cash-display').innerText = `$${profileData.balance.toFixed(2)}`;
            if (profileData.foodStamps !== undefined) document.getElementById('player-stamps-display').innerText = `🎫 ${profileData.foodStamps}`;
        }

        // ==========================================
        // ENVIRONMENT MODAL LOGIC (The Parks)
        // ==========================================
        const cityData = {
            'loc-default': { title: 'WELCOME TO THE BRICKYARD', sub: 'INDOOR HIGH STAKES' },
            'loc-tulsa': { title: 'WELCOME TO BLACK WALL STREET', sub: 'TULSA, OK' },
            'loc-atlanta': { title: 'WELCOME TO THE A', sub: 'ATLANTA, GA' },
            'loc-chicago': { title: 'WELCOME TO THE SOUTH SIDE', sub: 'CHICAGO, IL' },
            'loc-la': { title: 'WELCOME TO LEIMERT PARK', sub: 'LOS ANGELES, CA' },
            'loc-nyc': { title: 'WELCOME TO RUCKER PARK', sub: 'HARLEM, NY' },
            'loc-houston': { title: 'WELCOME TO H-TOWN', sub: 'HOUSTON, TX' },
            'loc-brickyard': { title: 'WELCOME TO THE BRICKYARD', sub: 'INDOOR HIGH STAKES' }
        };

        function openLocationModal() { document.getElementById('location-modal').classList.remove('hidden'); }
        function closeLocationModal() { document.getElementById('location-modal').classList.add('hidden'); }

        function equipLocation(locClass) {
            const bg = document.getElementById('app-background');
            bg.className = bg.className.replace(/\bloc-\S+/g, '');
            bg.classList.add(locClass);
            
            if(cityData[locClass]) {
                document.getElementById('city-watermark-title').innerText = cityData[locClass].title;
                document.getElementById('city-watermark-sub').innerText = cityData[locClass].sub;
            }

            closeLocationModal();
            showToast("Playground updated.", "success");
        }

        function equipSkin(skinClass) {
            const tiles = document.querySelectorAll('.domino-tile');
            tiles.forEach(tile => {
                tile.className = tile.className.replace(/skin-[a-z-]+/g, '').trim();
                tile.classList.add(skinClass);
            });
        }

        // ==========================================
        // GAME & MATCHMAKING ENGINE
        // ==========================================
        async function playTournamentRun(tournamentId, entryType) {
            showLoader("MATCHMAKING...");
            try {
                const matchMake = firebase.functions().httpsCallable('matchMakeAndDeal');
                
                let wagerAmt = 0;
                if (entryType === 'cash') {
                    if (tournamentId === 'yard_h2h') wagerAmt = 0.60;
                    else if (tournamentId === 'block_h2h') wagerAmt = 6.00;
                    else if (tournamentId === 'penthouse_h2h') wagerAmt = 300.00;
                    else wagerAmt = 2.50; 
                }
                
                const response = await matchMake({ 
                    wager: wagerAmt, 
                    mode: entryType === 'stamps' ? 'ai_tournament' : 'multiplayer',
                    difficulty: 'hard' 
                });

                hideLoader();

                if (response.data.status === 'waiting') {
                    showToast("Looking for an opponent... stay frosty.", "success");
                    return;
                }

                if (response.data.status === 'matched') {
                    navigate('screen-game');
                    const opponentText = response.data.isAI ? response.data.opponentName : "a Live Player";
                    showToast(`Matched against ${opponentText}!`, 'success');
                    
                    let scoreCounter = 0;
                    document.getElementById('my-score-display').innerText = scoreCounter;
                    const scoreInterval = setInterval(() => {
                        scoreCounter += 5;
                        document.getElementById('my-score-display').innerText = scoreCounter;
                        if (scoreCounter >= 35) {
                            clearInterval(scoreInterval);
                            showToast(`Run Finished! Submitted ${scoreCounter} points.`, 'success');
                            setTimeout(() => navigate('screen-lobby'), 2000);
                        }
                    }, 1000);
                }
            } catch (error) {
                hideLoader();
                showToast("Failed to join table.", "error");
            }
        }

        function sendChatMessage() {
            const input = document.getElementById('chat-input');
            if (input.value.trim() === '') return;
            const chatFeed = document.getElementById('chat-feed');
            chatFeed.innerHTML += `
            <div class="flex flex-col gap-1 mt-3">
                <div class="flex items-baseline gap-2">
                    <span class="text-amber-500 font-bold text-xs uppercase tracking-wider">You</span>
                    <span class="text-slate-300 text-xs">${input.value}</span>
                </div>
            </div>`;
            input.value = '';
            chatFeed.scrollTop = chatFeed.scrollHeight;
        }
    </script>
</body>
</html>
