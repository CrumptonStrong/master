<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brickyard Dominoes | The Hustle</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;900&family=Inter:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { 
            background-color: #020617; 
            color: #f8fafc; 
            font-family: 'Inter', sans-serif; 
        }
        
        /* ==========================================
           LOCATION ENVIRONMENTS (THE PARKS)
           ========================================== */
        
        /* 1. Landing Page: Full Screen Logo Background (Optimized Scaling) */
        .loc-default {
            background-color: #0b1528; /* Blends with the dark edges of your logo */
            background-image: url('logo.avif');
            background-size: contain; /* Prevents the zoom/cropping */
            background-position: center 25%; /* Centers it slightly higher to make room for bottom buttons */
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        /* 2. Black Wall Street, Tulsa */
        .loc-tulsa {
            background-color: #1a1710;
            background-image: linear-gradient(rgba(10,10,10,0.85), rgba(0,0,0,0.98)), url('https://upload.wikimedia.org/wikipedia/commons/thumb/1/1d/Tulsa_Skyline_from_the_air.jpg/1600px-Tulsa_Skyline_from_the_air.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
        }

        /* 3. The A, Atlanta */
        .loc-atlanta {
            background-color: #2a0f0a;
            background-image: linear-gradient(rgba(42,15,10,0.85), rgba(0,0,0,0.98)), url('https://upload.wikimedia.org/wikipedia/commons/thumb/a/a3/Atlanta_Skyline_from_Buckhead.jpg/1600px-Atlanta_Skyline_from_Buckhead.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
        }

        /* 4. South Side, Chicago */
        .loc-chicago {
            background-color: #0f172a;
            background-image: linear-gradient(rgba(15,23,42,0.85), rgba(2,6,23,0.98)), url('https://upload.wikimedia.org/wikipedia/commons/thumb/e/e9/Chicago_skyline_from_Adler_Planetarium_2016.jpg/1600px-Chicago_skyline_from_Adler_Planetarium_2016.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
        }

        /* 5. Leimert Park, LA */
        .loc-la {
            background-color: #431407;
            background-image: linear-gradient(rgba(67,20,7,0.85), rgba(0,0,0,0.98)), url('https://upload.wikimedia.org/wikipedia/commons/thumb/6/69/Los_Angeles_with_Mount_San_Antonio.jpg/1600px-Los_Angeles_with_Mount_San_Antonio.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
        }

        /* 6. Rucker Park, NYC */
        .loc-nyc {
            background-color: #061814;
            background-image: linear-gradient(rgba(6,24,20,0.85), rgba(0,0,0,0.98)), url('https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/New_york_times_square-terabass.jpg/1600px-New_york_times_square-terabass.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
        }

        /* 7. H-Town, Houston */
        .loc-houston {
            background-color: #2e1065;
            background-image: linear-gradient(rgba(46,16,101,0.85), rgba(0,0,0,0.98)), url('https://upload.wikimedia.org/wikipedia/commons/thumb/6/60/Houston_skyline_from_Eleanor_Tinsley_Park.jpg/1600px-Houston_skyline_from_Eleanor_Tinsley_Park.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
        }

        /* 8. The Brickyard (Indoor) */
        .loc-brickyard {
            background-color: #291a15;
            background-image: 
                linear-gradient(30deg, #1b100d 12%, transparent 12.5%, transparent 87%, #1b100d 87.5%, #1b100d),
                linear-gradient(150deg, #1b100d 12%, transparent 12.5%, transparent 87%, #1b100d 87.5%, #1b100d),
                linear-gradient(60deg, #3a221a 25%, transparent 25.5%, transparent 75%, #3a221a 75.5%, #3a221a);
            background-size: 40px 70px;
        }

        .table-shadow { box-shadow: inset 0 0 150px rgba(0,0,0,1); }
        .gold-border { border: 2px solid #d97706; box-shadow: 0 0 25px rgba(217, 119, 6, 0.4); }
        .branding-font { font-family: 'Orbitron', sans-serif; letter-spacing: 0.1em; }
        
        /* Skin Variables */
        .domino-tile {
            border-radius: 6px; position: relative; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex; align-items: center; justify-content: space-between; padding: 6px;
            background: var(--bg, linear-gradient(to bottom, #ffffff, #f1f5f9));
            box-shadow: 4px 4px 0px var(--shadow, #cbd5e1); color: var(--pip, #0f172a);
            border: 1px solid var(--border, #e2e8f0); cursor: pointer;
        }
        .skin-ivory { }
        .skin-midnight { --bg: #1e293b; --shadow: #020617; --pip: #f8fafc; --border: #334155; }
        .skin-brickyard-clay { --bg: #991b1b; --shadow: #450a0a; --pip: #fef2f2; --border: #b91c1c; }
        .skin-white-oak { --bg: #d1bfae; --shadow: #8c7b6b; --pip: #292524; --border: #e7d5c4; }
        .skin-pure-gold { --bg: linear-gradient(135deg, #fcd34d, #d97706); --shadow: #78350f; --pip: #451a03; --border: #fde68a; }
        
        .match-scroll::-webkit-scrollbar { width: 6px; }
        .match-scroll::-webkit-scrollbar-track { background: transparent; }
        .match-scroll::-webkit-scrollbar-thumb { background-color: #334155; border-radius: 20px; }
        
        .screen { display: none; opacity: 0; transition: opacity 0.4s ease-in-out; }
        .screen.active { display: flex; opacity: 1; }
        
        .table-logo-badge {
            position: absolute; top: 24px; left: 24px; opacity: 0.35;
            pointer-events: none; user-select: none; filter: drop-shadow(0 0 10px rgba(0,0,0,0.8));
        }

        @media (min-width: 768px) {
            .loc-default {
                background-size: 60%; /* Scales it slightly down on large desktop monitors for a cleaner look */
            }
        }
    </style>
</head>
